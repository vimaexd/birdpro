{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Bird Pro",
    "version": "1.1.0",
    "identifier": "birdpro",
    "mainBinaryName": "birdpro",
    "build": {
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../build"
    },
    "app": {
        "windows": [
            {
                "title": "Bird Pro",
                "width": 1280,
                "height": 720,
                "minWidth": 540,
                "minHeight": 600,
                "visible": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "category": "Utility",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": ["assets/"],
        "windows": {
            "nsis": {
                "sidebarImage": "./assets-installer/installer-sidebar.bmp"
            }
        },
        "macOS": {
            "files": {
                "Resources/Assets.car": "./icons/macos/gen/Assets.car"
            }
        }
    }
}
